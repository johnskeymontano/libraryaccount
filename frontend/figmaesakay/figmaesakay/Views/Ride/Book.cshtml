@{
    ViewData["Title"] = "Book a Ride";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            
            <!-- Back Button -->
            <a asp-controller="Home" asp-action="Index" class="text-decoration-none text-muted mb-3 d-inline-block">
                &larr; Back to Home
            </a>

            <div class="card-custom">
                <h3 class="mb-4" style="color: var(--primary-blue);">🚗 Book a Ride</h3>
                
                <form>
                    <!-- Pick Up -->
                    <div class="mb-3">
                        <label class="form-label text-muted">Pick-up Location</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white text-primary">📍</span>
                            <input type="text" class="form-control" placeholder="Current Location (Barangay Fatima)" />
                        </div>
                    </div>

                    <!-- Drop Off -->
                    <div class="mb-4">
                        <label class="form-label text-muted">Destination</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white text-danger">🏁</span>
                            <input type="text" class="form-control" placeholder="Search destination..." />
                        </div>
                    </div>

                    <!-- Vehicle Type Selection -->
                    <div class="mb-4">
                        <label class="form-label">Select Vehicle</label>
                        <div class="d-flex justify-content-between gap-2">
                            <button type="button" class="btn btn-outline-primary w-100 active">Tricycle</button>
                            <button type="button" class="btn btn-outline-secondary w-100">Jeepney</button>
                            <button type="button" class="btn btn-outline-secondary w-100">Taxi</button>
                        </div>
                    </div>

                    <!-- Confirm Button -->
                    <button type="button" class="btn-esakay-primary" onclick="alert('Finding nearby drivers...')">
                        Find a Ride Now
                    </button>
                </form>
            </div>

            <!-- Map Placeholder (Image) -->
            <div class="mt-3 text-center p-4 bg-white rounded border">
                <p class="text-muted">🗺️ Map View Area</p>
                <small>Makikita dito ang live map sa future updates.</small>
            </div>

        </div>
    </div>
</div>