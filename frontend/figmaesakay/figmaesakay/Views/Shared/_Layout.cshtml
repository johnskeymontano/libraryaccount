<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>eSakay Gensan</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body>
    
    <div class="app-container">
        <!-- Page Content -->
        @RenderBody()

        <!-- BOTTOM NAVIGATION -->
        <nav class="bottom-nav">
            <a asp-controller="Home" asp-action="Index" class="nav-item active">
                <i class="fa-solid fa-house"></i> Home
            </a>
            <a asp-controller="Ride" asp-action="Track" class="nav-item">
                <i class="fa-solid fa-location-dot"></i> Track
            </a>
            <a asp-controller="Ride" asp-action="Fare" class="nav-item">
                <i class="fa-solid fa-calculator"></i> Fare
            </a>
            <a asp-controller="Ride" asp-action="Safety" class="nav-item">
                <i class="fa-solid fa-shield-halved"></i> Safety
            </a>
            <a asp-controller="Home" asp-action="Community" class="nav-item">
                <i class="fa-solid fa-users"></i> Community
            </a>
        </nav>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>