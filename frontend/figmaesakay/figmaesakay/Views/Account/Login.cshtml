@{ Layout = null; }
<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <title>Login</title>
</head>
<body>
    <div class="app-container" style="display:flex; align-items:center;">
        <div class="auth-box">
            <h1 style="font-size:3rem;">⚡</h1>
            <h3 style="font-weight:bold;">Welcome Back</h3>
            
            <form onsubmit="handleLogin(event)">
                <input id="email" type="email" class="form-control" placeholder="Email" required />
                <input id="password" type="password" class="form-control" placeholder="Password" required />
                <button type="submit" class="btn btn-primary text-white">Login</button>
            </form>

            <p class="mt-3 small">
                No account? <a href="/Account/Register" style="color:#0156D1;">Register</a>
            </p>
        </div>
    </div>

    <script>
        async function handleLogin(e) {
            e.preventDefault();
            const email = document.getElementById('email').value;
            const password = document.getElementById('password').value;

            try {
                // KONEKTA ULIT SA BACKEND (Port 5000)
                const response = await fetch('http://localhost:5000/api/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email, password })
                });

                const result = await response.json();

                if (response.ok) {
                    // I-save ang user details sa browser memory
                    localStorage.setItem('user', JSON.stringify(result));
                    alert('Login Success!');
                    window.location.href = '/Home/Index'; // Pasok sa Dashboard
                } else {
                    alert('Login Failed: ' + result.message);
                }
            } catch (err) {
                alert('Cannot connect to Backend (Port 5000).');
            }
        }
    </script>
</body>
</html>